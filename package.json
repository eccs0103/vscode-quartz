{
	"name": "quartz-language",
	"displayName": "Quartz language",
	"description": "Complete language support for the Quartz programming language including syntax highlighting, formatting, IntelliSense, and more.",
	"version": "0.5.0",
	"publisher": "eccs0103",
	"repository": {
		"type": "git",
		"url": "https://github.com/eccs0103/vscode-quartz.git"
	},
	"icon": "images/icon.png",
	"engines": {
		"vscode": "^1.118.0",
		"node": ">=22 <25"
	},
	"categories": [
		"Programming Languages",
		"Formatters",
		"Linters"
	],
	"keywords": [
		"quartz",
		"qrz",
		"syntax",
		"highlighting",
		"formatter",
		"language-server"
	],
	"activationEvents": [
		"onLanguage:qrz"
	],
	"type": "module",
	"main": "./out/controllers/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "qrz",
				"aliases": [
					"Quartz",
					"Quartz language"
				],
				"extensions": [
					".qrz"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "qrz",
				"scopeName": "source.qrz",
				"path": "./syntaxes/qrz.tmLanguage.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/vscode": "^1.118.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"adaptive-extender": "^0.9.13",
		"vscode-languageclient": "^9.0.1",
		"vscode-languageserver": "^9.0.1",
		"vscode-languageserver-textdocument": "^1.0.12"
	}
}
